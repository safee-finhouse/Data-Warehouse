# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# Minimum 32 characters. Generate with: openssl rand -hex 32
APP_SECRET=replace_with_at_least_32_character_secret_here_xx

# ─── Database ─────────────────────────────────────────────────────────────────
# Railway injects DATABASE_URL automatically in production.
# For local dev, point at your local PostgreSQL instance.
DATABASE_URL=postgresql://postgres:password@localhost:5432/finhouse

# ─── Xero OAuth2 ──────────────────────────────────────────────────────────────
# Create a Xero app at https://developer.xero.com/app/manage
# Set the redirect URI to match XERO_REDIRECT_URI below
XERO_CLIENT_ID=your_xero_client_id
XERO_CLIENT_SECRET=your_xero_client_secret

# Must match the redirect URI configured in your Xero app settings
# In production: https://your-railway-domain.up.railway.app/xero/callback
XERO_REDIRECT_URI=http://localhost:3000/xero/callback

# ─── Scheduler ────────────────────────────────────────────────────────────────
# Cron expressions (UTC). Set SCHEDULER_ENABLED=false to disable in staging.
SCHEDULER_ENABLED=true
SYNC_FULL_CRON=0 2 * * *
SYNC_INCREMENTAL_CRON=*/20 * * * *

# ─── Logging ──────────────────────────────────────────────────────────────────
# debug | info | warn | error (default: info)
LOG_LEVEL=info
